.container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #FAFAFA;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #212121;
  text-align: center;
  margin-bottom: 24rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #757575;
  text-align: center;
  margin-bottom: 80rpx;
}

.btn-primary {
  background-color: #4CAF50;
  color: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  width: 100%;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #4CAF50;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: 2rpx solid #4CAF50;
  width: 100%;
  box-sizing: border-box;
}

.btn-secondary::after {
  border: none;
}
