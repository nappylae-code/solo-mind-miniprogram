<view class="container">
  <view class="content">

    <!-- Logo -->
    <image
      class="app-logo"
      src="/images/nearmi-logo.png"
      mode="aspectFit"
    />

    <text class="title">欢迎使用 Nearmi</text>
    <text class="subtitle">设置您的头像和昵称</text>

    <!-- Step 1: Choose Avatar -->
    <button
      class="avatar-btn"
      open-type="chooseAvatar"
      bind:chooseavatar="onChooseAvatar"
    >
      <image
        class="avatar-preview"
        src="{{avatarUrl || '/images/profile.png'}}"
        mode="aspectFill"
      />
      <text class="avatar-hint">点击选择头像</text>
    </button>

    <!-- Step 2: Enter Nickname -->
    <view class="nickname-wrap">
      <input
        class="nickname-input"
        type="nickname"
        placeholder="点击填写昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
    </view>

    <!-- Step 3: Confirm -->
    <button
      class="btn-primary {{loading ? 'btn-disabled' : ''}}"
      bindtap="onConfirm"
      disabled="{{loading}}"
    >
      {{loading ? '正在进入...' : '进入 Nearmi'}}
    </button>

  </view>
</view>