<!-- pages/profile/profile.wxml -->
<scroll-view class="container" scroll-y>

<!-- ══ 导航栏 ══ -->
<view class="nav-bar">
  <text class="nav-title">我的</text>
  <view class="nav-settings" bind:tap="onSettings">
    <text class="settings-icon">⚙️</text>
  </view>
</view>

<!-- ══ 用户信息卡片 ══ -->
<view class="user-card">
  <view class="avatar-wrap">
    <image
      wx:if="{{userAvatarUrl}}"
      class="avatar"
      src="{{userAvatarUrl}}"
      mode="aspectFill"
    />
    <view wx:else class="avatar-placeholder">
      <text class="avatar-emoji">🌿</text>
    </view>
  </view>
  <text class="user-name">{{userNickname || '独居者'}}</text>
  <text class="join-days">加入 Nearmi 第 {{joinDays}} 天</text>

  <!-- 数据概览 -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{totalCheckin}}</text>
      <text class="stat-label">总打卡天数</text>
    </view>
    <view class="stat-divider" />
    <view class="stat-item">
      <text class="stat-num">{{totalDiary}}</text>
      <text class="stat-label">总日记篇数</text>
    </view>
    <view class="stat-divider" />
    <view class="stat-item">
      <text class="stat-num">{{streak}}</text>
      <text class="stat-label">连续打卡天</text>
    </view>
  </view>
</view>

<!-- ══ 情绪报告入口 ══ -->
<view class="section-card tap-card" bind:tap="goToReport">
  <text class="section-icon">📊</text>
  <text class="section-text">我的情绪报告</text>
  <text class="section-arrow">›</text>
</view>

<!-- ══ 成就勋章 ══ -->
<view class="section-card badge-section">
  <view class="badge-header">
    <text class="section-icon">🏅</text>
    <text class="section-text">我的成就</text>
  </view>
  <view class="badge-grid">
    <view
      wx:for="{{badges}}"
      wx:key="id"
      class="badge-item {{item.unlocked ? 'badge-unlocked' : 'badge-locked'}}"
    >
      <text class="badge-emoji">{{item.emoji}}</text>
      <text class="badge-label">{{item.label}}</text>
      <text wx:if="{{!item.unlocked}}" class="badge-lock-icon">🔒</text>
    </view>
  </view>
</view>

<!-- ══ 会员升级入口 ══ -->
<view class="member-card tap-card" bind:tap="goToMembership">
  <view class="member-left">
    <text class="member-icon">💎</text>
    <view class="member-text-wrap">
      <text class="member-title">升级会员</text>
      <text class="member-subtitle">解锁趋势图·年历·数据导出</text>
    </view>
  </view>
  <text class="section-arrow member-arrow">›</text>
</view>

<!-- ══ 功能列表 ══ -->
<view class="menu-section">
  <view class="menu-item tap-card" bind:tap="onExportData">
    <text class="menu-icon">📤</text>
    <text class="menu-text">导出我的数据</text>
    <view class="menu-right">
      <text wx:if="{{!isMember}}" class="vip-tag">💎</text>
      <text class="section-arrow">›</text>
    </view>
  </view>

  <view class="menu-item tap-card" bind:tap="onPrivacySettings">
    <text class="menu-icon">🔒</text>
    <text class="menu-text">隐私设置</text>
    <text class="section-arrow">›</text>
  </view>

  <view class="menu-item tap-card" bind:tap="onAbout">
    <text class="menu-icon">❓</text>
    <text class="menu-text">关于 Nearmi</text>
    <text class="section-arrow">›</text>
  </view>

  <view class="menu-item tap-card" bind:tap="onFeedback">
    <text class="menu-icon">📞</text>
    <text class="menu-text">帮助与反馈</text>
    <text class="section-arrow">›</text>
  </view>
</view>

<view class="bottom-spacer" />

</scroll-view>