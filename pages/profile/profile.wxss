/* pages/profile/profile.wxss */

/* ── 全局 ── */
.container {
  background-color: #F7F3EF;
  min-height: 100vh;
}

/* ── 导航栏 ── */
.nav-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 56rpx 40rpx 24rpx;
  background-color: #F7F3EF;
}

.nav-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #212121;
}

.nav-settings {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon {
  font-size: 44rpx;
}

/* ── 用户信息卡片 ── */
.user-card {
  background-color: #FFFFFF;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 48rpx 32rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.avatar-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  background-color: #E8F5E9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 72rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #212121;
  margin-bottom: 10rpx;
}

.join-days {
  font-size: 26rpx;
  color: #9E9E9E;
  margin-bottom: 40rpx;
}

/* ── 数据概览 ── */
.stats-row {
  display: flex;
  flex-direction: row;
  width: 100%;
  border-top: 1rpx solid #F0F0F0;
  padding-top: 32rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #4CAF50;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: #9E9E9E;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  background-color: #F0F0F0;
  margin: 4rpx 0;
}

/* ── 通用卡片 ── */
.section-card {
  background-color: #FFFFFF;
  margin: 0 32rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tap-card {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.tap-card:active {
  opacity: 0.7;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.section-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #212121;
}

.section-arrow {
  font-size: 36rpx;
  color: #BDBDBD;
  font-weight: 300;
}

/* ── 成就勋章 ── */
.badge-section {
  display: flex;
  flex-direction: column;
}

.badge-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 28rpx;
}

.badge-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx;
}

.badge-item {
  width: calc(33.33% - 14rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  position: relative;
}

.badge-unlocked {
  background-color: #F1F8E9;
  border: 1rpx solid #C8E6C9;
}

.badge-locked {
  background-color: #F5F5F5;
  border: 1rpx solid #E0E0E0;
  opacity: 0.55;
}

.badge-emoji {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.badge-label {
  font-size: 22rpx;
  color: #555555;
  text-align: center;
}

.badge-lock-icon {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 22rpx;
}

/* ── 会员卡片 ── */
.member-card {
  background: linear-gradient(135deg, #1B5E20 0%, #388E3C 100%);
  margin: 0 32rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx 36rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.30);
}

.member-card:active {
  opacity: 0.85;
}

.member-left {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.member-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.member-text-wrap {
  display: flex;
  flex-direction: column;
}

.member-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.member-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 6rpx;
}

.member-arrow {
  color: rgba(255, 255, 255, 0.8);
}

/* ── 功能菜单 ── */
.menu-section {
  background-color: #FFFFFF;
  margin: 0 32rpx 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 34rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #212121;
}

.menu-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.vip-tag {
  font-size: 26rpx;
}

/* ── 底部留白 ── */
.bottom-spacer {
  height: 40rpx;
}