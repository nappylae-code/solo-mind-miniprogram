.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #FAFAFA;
}

.scroll {
  flex: 1;
  display: flex;
}

.scroll .wrapper {
  flex: 1;
  padding: 32rpx 32rpx;
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 64rpx;
  font-weight: 700;
  text-align: center;
  color: #212121;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  text-align: center;
  color: #757575;
  margin-bottom: 48rpx;
}

.input {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid #E0E0E0;
  height: 96rpx;
  padding: 20rpx 32rpx;
  font-size: 30rpx;
  line-height: 1.4;
  color: #212121;
  margin-bottom: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.input:focus {
  border-color: #4CAF50;
}

.input-with-button {
  position: relative;
  margin-bottom: 32rpx;
  width: 100%;
}

.input-with-button .input {
  width: 100%;
  padding-right: 120rpx;
  box-sizing: border-box;
}

.toggle-password-btn {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  background: transparent;
  border: none;
  color: #4CAF50;
  font-size: 28rpx;
  padding: 8rpx 16rpx;
  line-height: 1;
  min-width: 80rpx;
}

.toggle-password-btn::after {
  border: none;
}

.btn-primary {
  background-color: #4CAF50;
  color: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  font-size: 36rpx;
  font-weight: 600;
  border: none;
  margin-top: 16rpx;
  width: 100%;
}

.btn-primary::after {
  border: none;
}

.btn-disabled {
  opacity: 0.6;
}

.back-link {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
}

.back-text {
  font-size: 30rpx;
  color: #4CAF50;
  font-weight: 500;
}
