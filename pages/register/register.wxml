<view class="container">
  <scroll-view scroll-y class="scroll">
    <view class="wrapper">
      <text class="title">创建账号</text>
      <text class="subtitle">注册开始使用</text>

      <input
        class="input"
        placeholder="邮箱"
        placeholder-style="color: #9E9E9E;"
        value="{{email}}"
        bindinput="onEmailInput"
        type="text"
        auto-capitalize="none"
      />

      <view class="input-with-button">
        <input
          class="input"
          placeholder="密码"
          placeholder-style="color: #9E9E9E;"
          value="{{password}}"
          bindinput="onPasswordInput"
          type="{{showPassword ? 'text' : 'password'}}"
          auto-capitalize="none"
        />
        <button class="toggle-password-btn" bindtap="togglePasswordVisibility">
          {{showPassword ? '隐藏' : '显示'}}
        </button>
      </view>

      <input
        class="input"
        placeholder="确认密码"
        placeholder-style="color: #9E9E9E;"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
        type="{{showPassword ? 'text' : 'password'}}"
        auto-capitalize="none"
      />

      <button
        class="btn-primary {{loading ? 'btn-disabled' : ''}}"
        bindtap="handleRegister"
        disabled="{{loading}}"
        loading="{{loading}}"
      >
        {{loading ? '创建中...' : '注册'}}
      </button>

      <view class="back-link" bindtap="goBack">
        <text class="back-text">已有账号？登录</text>
      </view>
    </view>
  </scroll-view>
</view>
