/* ===== Container ===== */
.container {
  background-color: #FAFAFA;
  min-height: 100vh;
}

.scroll-content {
  height: 100vh;
  padding: 0 32rpx 120rpx;
  box-sizing: border-box;
}

/* ===== Header ===== */
.header-section {
  padding: 48rpx 0 24rpx;
  text-align: center;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #212121;
}

/* ===== Prompt Card ===== */
.prompt-card {
  background-color: #EEF2FF;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.prompt-label {
  font-size: 24rpx;
  color: #7986CB;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.prompt-text {
  font-size: 28rpx;
  color: #3949AB;
  line-height: 1.6;
}

/* ===== Write Card ===== */
.write-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  min-height: 240rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.diary-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: #212121;
  line-height: 1.8;
}

/* ===== Save Button ===== */
.save-btn {
  background-color: #FFFFFF;
  color: #212121;
  border-radius: 16rpx;
  border: 2rpx solid #E0E0E0;
  font-size: 34rpx;
  font-weight: 600;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.save-btn::after {
  border: none;
}

.save-btn-disabled {
  color: #BDBDBD !important;
}

/* ===== History Section ===== */
.history-section {
  padding-top: 8rpx;
}

.history-title {
  font-size: 28rpx;
  color: #757575;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
}

/* ===== Entry Row ===== */
.entry-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.entry-date {
  font-size: 26rpx;
  color: #757575;
  width: 120rpx;
  flex-shrink: 0;
}

.entry-preview {
  font-size: 28rpx;
  color: #424242;
  flex: 1;
}

/* ===== Empty State ===== */
.empty-history {
  padding: 32rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #BDBDBD;
}

/* ===== Unlock Row ===== */
.unlock-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-top: 28rpx;
}

.unlock-text {
  font-size: 26rpx;
  color: #757575;
  flex: 1;
}

.vip-badge {
  font-size: 22rpx;
  color: #FFFFFF;
  background-color: #FFB300;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 600;
}