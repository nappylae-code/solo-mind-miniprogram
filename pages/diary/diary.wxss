/* ===== Container ===== */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F5F5;
  position: relative;
}

/* ===== 搜索框 ===== */
.search-bar {
  padding: 20rpx 24rpx 12rpx;
  background-color: #F5F5F5;
}

.search-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #212121;
}

.search-clear {
  font-size: 24rpx;
  color: #BDBDBD;
  padding: 4rpx 8rpx;
}

/* ===== 情绪筛选 Tab（竖排：emoji + 文字）===== */
.mood-filter-bar {
  background-color: #F5F5F5;
  white-space: nowrap;
}

.mood-filter-inner {
  display: flex;
  flex-direction: row;
  padding: 8rpx 24rpx 16rpx;
  gap: 12rpx;
}

.mood-filter-item {
  display: inline-flex;
  flex-direction: column;    /* ✅ 竖排 */
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background-color: #EEEEEE;
  flex-shrink: 0;
  gap: 4rpx;
  min-width: 80rpx;
}

.mood-filter-active {
  background-color: #4CAF50;
}

.filter-emoji {
  font-size: 32rpx;
}

.filter-label {
  font-size: 20rpx;
  color: #757575;
}

.mood-filter-active .filter-label {
  color: #FFFFFF;
}

/* ===== 列表滚动区 ===== */
.scroll-content {
  flex: 1;
  overflow: hidden;
}

/* ===== 月份标题 ===== */
.month-header {
  padding: 24rpx 24rpx 12rpx;
}

.month-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #9E9E9E;
}

/* ===== 日记卡片 ===== */
.entry-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #FFFFFF;
  margin: 0 24rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  gap: 16rpx;
}

.entry-left {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.entry-emoji {
  font-size: 44rpx;
}

.entry-middle {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.entry-date {
  font-size: 26rpx;
  font-weight: 600;
  color: #212121;
}

.entry-preview {
  font-size: 24rpx;
  color: #9E9E9E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.entry-right {
  flex-shrink: 0;
}

.entry-arrow {
  font-size: 28rpx;
  color: #BDBDBD;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  gap: 16rpx;
}

.empty-emoji {
  font-size: 80rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #757575;
  font-weight: 600;
}

.empty-sub {
  font-size: 26rpx;
  color: #BDBDBD;
}

/* ===== 底部占位 ===== */
.bottom-spacer {
  height: 120rpx;
}

/* ===== FAB 悬浮按钮 ===== */
.fab {
  position: fixed;
  right: 48rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background-color: #4CAF50;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.4);
}

.fab-icon {
  font-size: 40rpx;
}

/* 情绪筛选图片 */
.filter-image {
  width: 40rpx;
  height: 40rpx;
}

.filter-all-text {
  font-size: 32rpx;
}

/* 列表项情绪图片 */
.entry-mood-image {
  width: 56rpx;
  height: 56rpx;
}