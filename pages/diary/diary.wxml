<view class="container">

<!-- 搜索框 -->
<view class="search-bar">
  <view class="search-inner">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      placeholder="搜索日记..."
      placeholder-style="color: #BDBDBD;"
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
    />
    <text
      class="search-clear"
      wx:if="{{searchKeyword}}"
      bindtap="onSearchClear"
    >✕</text>
  </view>
</view>

<!-- 情绪筛选 Tab -->
<scroll-view scroll-x class="mood-filter-bar">
  <view class="mood-filter-inner">
    <block wx:for="{{moodFilters}}" wx:key="key">
      <view
        class="mood-filter-item {{activeMoodFilter === item.key ? 'mood-filter-active' : ''}}"
        bindtap="onMoodFilterTap"
        data-key="{{item.key}}"
      >
        <text wx:if="{{item.emoji}}">{{item.emoji}} </text>
        <text>{{item.key === 'ALL' ? '全部' : item.label}}</text>
      </view>
    </block>
  </view>
</scroll-view>

<!-- 日记列表 -->
<scroll-view scroll-y class="scroll-content">

  <!-- 有数据 -->
  <block wx:if="{{monthGroups.length > 0}}">
    <block wx:for="{{monthGroups}}" wx:key="monthLabel">
      <!-- 月份标题 -->
      <view class="month-header">
        <text class="month-label">📅 {{item.monthLabel}}</text>
      </view>

      <!-- 该月日记列表 -->
      <block wx:for="{{item.entries}}" wx:key="date" wx:for-item="entry">
        <view
          class="entry-card"
          bindtap="onEntryTap"
          data-date="{{entry.date}}"
        >
          <view class="entry-left">
            <text class="entry-emoji">{{entry.moodEmoji}}</text>
          </view>
          <view class="entry-middle">
            <text class="entry-date">{{entry.displayDate}}</text>
            <text class="entry-preview">{{entry.preview}}</text>
          </view>
          <view class="entry-right">
            <text class="entry-arrow">→</text>
          </view>
        </view>
      </block>
    </block>
  </block>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading}}">
    <text class="empty-emoji">📔</text>
    <text class="empty-text">还没有日记</text>
    <text class="empty-sub">点击右下角按钮开始写第一篇</text>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-spacer"></view>
</scroll-view>

<!-- FAB 悬浮新建按钮 -->
<view class="fab" bindtap="onNewDiary">
  <text class="fab-icon">✏️</text>
</view>

</view>