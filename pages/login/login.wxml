<view class="container">
  <scroll-view scroll-y class="scroll">
    <view class="wrapper">
      <text class="title">SoloMind</text>
      <text class="subtitle">登录以追踪您的心情</text>

      <input
        class="input"
        placeholder="邮箱"
        placeholder-style="color: #9E9E9E;"
        value="{{email}}"
        bindinput="onEmailInput"
        type="text"
        auto-capitalize="none"
        auto-focus="false"
      />

      <view class="input-with-button">
        <input
          class="input"
          placeholder="密码"
          placeholder-style="color: #9E9E9E;"
          value="{{password}}"
          bindinput="onPasswordInput"
          type="{{showPassword ? 'text' : 'password'}}"
          auto-capitalize="none"
        />
        <button class="toggle-password-btn" bindtap="togglePasswordVisibility">
          {{showPassword ? '隐藏' : '显示'}}
        </button>
      </view>

      <button
        class="btn-primary {{loading ? 'btn-disabled' : ''}}"
        bindtap="handleLogin"
        disabled="{{loading}}"
        loading="{{loading}}"
      >
        登录
      </button>

      <view class="register-link" bindtap="goToRegister">
        <text class="register-text">还没有账号？立即注册</text>
      </view>
    </view>
  </scroll-view>
</view>
