<view class="container">
  <scroll-view scroll-y class="scroll-content">
    <!-- Header -->
    <view class="header-row">
      <text class="header">今日心情</text>
      <button class="logout-button" bindtap="handleLogout" size="mini">退出登录</button>
    </view>
    <text class="subheader">每天只需要15秒</text>

    <!-- Mood Selection Grid -->
    <scroll-view scroll-x class="mood-grid" show-scrollbar="{{false}}">
      <view class="mood-row">
        <block wx:for="{{MOODS}}" wx:key="key">
          <MoodCard
            mood="{{item}}"
            selected="{{selectedMood === item.key}}"
            bind:onpress="onSelectMood"
            data-mood-key="{{item.key}}"
          />
        </block>
      </view>
    </scroll-view>

    <!-- Note Input -->
    <view class="note-section">
      <text class="prompt" wx:if="{{selectedMood}}">
        今天什么让你感到{{selectedMoodObj ? (selectedMoodObj.label) : ''}}？
      </text>
      <textarea
        class="text-input"
        placeholder="写几句..."
        placeholder-style="color: #BDBDBD;"
        value="{{note}}"
        bindinput="onNoteInput"
        auto-height
        maxlength="500"
      />
    </view>

    <!-- Week History -->
    <view class="week-section">
      <text class="week-label">{{weekLabel}}</text>
      <view class="week-days">
        <block wx:for="{{weekDays}}" wx:key="index">
          <view class="week-day">
            <text class="week-day-label">{{item.label}}</text>
            <view class="week-day-circle {{item.hasEntry ? 'week-day-checked' : ''}}">
              <text class="week-day-check" wx:if="{{item.hasEntry}}">✓</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- Streak -->
    <text class="streak">已连续打卡 {{streak}} 天</text>

    <!-- Save Button -->
    <button class="save-button btn-primary" bindtap="handleSave">
      保存今天的心情
    </button>
  </scroll-view>
</view>
