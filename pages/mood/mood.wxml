<view class="container">
  <scroll-view scroll-y class="scroll-content">

    <!-- Header: Greeting + Date -->
    <view class="header-section">
      <text class="greeting">{{greeting}}，{{userNickname || '朋友'}}</text>
      <text class="date-string">{{dateString}}</text>
    </view>

    <!-- Mood Check-in Card -->
    <view class="card mood-card">
      <text class="card-title">今日心情打卡</text>

      <!-- Mood Emojis -->
      <view class="mood-row">
        <block wx:for="{{MOODS}}" wx:key="key">
          <MoodCard
            mood="{{item}}"
            selected="{{selectedMood === item.key}}"
            bind:onpress="onSelectMood"
            data-mood-key="{{item.key}}"
          />
        </block>
      </view>

      <!-- Week Calendar -->
      <view class="week-days">
        <block wx:for="{{weekDays}}" wx:key="index">
          <view class="week-day">
            <text class="week-day-label">{{item.label}}</text>
            <view class="week-day-square {{item.hasEntry ? 'week-day-done' : (item.isToday ? 'week-day-today' : '')}}"></view>
          </view>
        </block>
      </view>

      <!-- Streak -->
      <text class="streak">连续打卡 {{streak}} 天 🔥</text>

      <!-- Note Input (compact) -->
      <textarea
        class="note-input"
        placeholder="写几句今天的感受..."
        placeholder-style="color: #BDBDBD;"
        value="{{note}}"
        bindinput="onNoteInput"
        maxlength="500"
        show-count="{{false}}"
      />

      <!-- Save Button -->
      <button class="save-button" bindtap="handleSave">完成打卡</button>
    </view>

    <!-- Daily Quote Card -->
    <view class="card quote-card">
      <text class="card-title">今日推荐</text>
      <text class="quote-text">{{dailyQuote}}</text>
    </view>

    <!-- Community Hot Post Card -->
    <view class="card community-card" bindtap="onGoToCommunity">
      <text class="card-title">社区热帖</text>
      <text class="community-text">去社区看看大家在聊什么 →</text>
    </view>

  </scroll-view>
</view>