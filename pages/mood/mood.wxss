/* ===== Container ===== */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #F5F5F5;
}

.scroll-content {
  flex: 1;
  padding: 32rpx 24rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* ===== Header ===== */
.header-section {
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.greeting {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #212121;
  margin-bottom: 8rpx;
}

.date-string {
  display: block;
  font-size: 26rpx;
  color: #9E9E9E;
}

/* ===== Card Base ===== */
.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #212121;
  margin-bottom: 20rpx;
}

/* ===== Mood Card ===== */
.mood-card {}

.mood-row {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

/* ===== Week Calendar ===== */
.week-days {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.week-day-label {
  font-size: 20rpx;
  color: #9E9E9E;
}

.week-day-square {
  width: 56rpx;
  height: 20rpx;
  border-radius: 6rpx;
  background-color: #E0E0E0;
}

.week-day-done {
  background-color: #4CAF50;
}

.week-day-today {
  background-color: #9C27B0;
  opacity: 0.4;
}

/* ===== Streak ===== */
.streak {
  display: block;
  font-size: 24rpx;
  color: #757575;
  margin-bottom: 16rpx;
}

/* ===== Note Input (compact) ===== */
.note-input {
  width: 100%;
  min-height: 100rpx;
  max-height: 160rpx;
  background-color: #FAFAFA;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #212121;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  overflow-y: auto;
}

/* ===== Save Button ===== */
.save-button {
  width: 100%;
  background-color: #4CAF50;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 20rpx 0;
  border: none;
}

.save-button::after {
  border: none;
}

/* ===== Quote Card ===== */
.quote-card {}

.quote-text {
  display: block;
  font-size: 26rpx;
  color: #616161;
  line-height: 1.6;
}

/* ===== Community Card ===== */
.community-card {}

.community-text {
  display: block;
  font-size: 26rpx;
  color: #616161;
  line-height: 1.6;
}