/* ===== Container ===== */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #F5F5F5;
}

.scroll-content {
  flex: 1;
  padding: 32rpx 24rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* ===== Header ===== */
.header-section {
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.greeting {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #212121;
  margin-bottom: 8rpx;
}

.date-string {
  display: block;
  font-size: 26rpx;
  color: #9E9E9E;
}

/* ===== Card Base ===== */
.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #212121;
  margin-bottom: 24rpx;
}

/* ===== 情绪打卡卡片 ===== */
.mood-row {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

/* ===== 备注输入框 ===== */
.note-input {
  width: 100%;
  min-height: 88rpx;
  max-height: 200rpx;
  background-color: #FAFAFA;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #212121;
  box-sizing: border-box;
  overflow-y: auto;
}

/* ===== 字数计数 ===== */
.note-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #BDBDBD;
  margin-top: 8rpx;
  margin-bottom: 20rpx;
}

/* ===== 保存按钮 ===== */
.save-button {
  width: 100%;
  background-color: #4CAF50;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 22rpx 0;
  border: none;
  margin-top: 4rpx;
}

.save-button::after {
  border: none;
}

/* ===== 周历卡片 ===== */
.week-days {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.week-day-label {
  font-size: 22rpx;
  color: #9E9E9E;
}

.week-day-label-today {
  color: #4CAF50;
  font-weight: 700;
}

/* 格子基础样式 */
.week-day-cell {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 已打卡：浅绿底 + emoji */
.cell-done {
  background-color: #E8F5E9;
}

/* 今天未打卡：绿色虚线边框高亮 */
.cell-today {
  background-color: #FFFFFF;
  border: 2rpx dashed #4CAF50;
}

/* 其他未打卡：灰色 */
.cell-empty {
  background-color: #EEEEEE;
}

.week-day-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.week-day-dot {
  font-size: 40rpx;
  color: #4CAF50;
  font-weight: bold;
}

/* ===== Streak ===== */
.streak {
  display: block;
  font-size: 26rpx;
  color: #757575;
  font-weight: 500;
}

/* ===== 语录卡片 ===== */
.quote-text {
  display: block;
  font-size: 28rpx;
  color: #616161;
  line-height: 1.8;
  font-style: italic;
}