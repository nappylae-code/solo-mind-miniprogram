/* ── 整体布局 ── */
.page-wrap {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F7F3EF;
  position: relative;
  overflow: hidden;
}

/* ── 今日活跃 ── */
.active-banner {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 40rpx 20rpx;  /* ← 顶部间距收紧，导航栏已由系统提供 */
  flex-shrink: 0;
}

.active-dot {
  font-size: 20rpx;
  color: #4CAF50;
  margin-right: 10rpx;
}

.active-text {
  font-size: 26rpx;
  color: #9E9E9E;
}

.active-count {
  font-size: 26rpx;
  font-weight: 700;
  color: #4CAF50;
}

/* ── 情绪筛选 ── */
.filter-scroll {
  flex-shrink: 0;
  white-space: nowrap;
}

.filter-row {
  display: flex;
  flex-direction: row;
  padding: 0 32rpx 24rpx;
  gap: 16rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  background-color: #EEEBE6;
  font-size: 28rpx;
  color: #757575;
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-chip-active {
  background-color: #4CAF50;
  color: #FFFFFF;
  font-weight: 600;
}

/* ── 帖子列表 ── */
.post-list {
  flex: 1;
  overflow: hidden;
}

/* ── 空状态 ── */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #BDBDBD;
}

/* ── 帖子卡片 ── */
.post-card {
  background-color: #FFFFFF;
  margin: 0 32rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.post-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-mood-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.post-author {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #555555;
}

.post-time {
  font-size: 24rpx;
  color: #BDBDBD;
}

.post-content {
  font-size: 30rpx;
  color: #212121;
  line-height: 1.7;
  display: block;
  margin-bottom: 28rpx;
}

/* ── 回应按钮 ── */
.reaction-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  border-top: 1rpx solid #F5F5F5;
  padding-top: 24rpx;
}

.reaction-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  background-color: #F5F5F5;
}

.reaction-btn:active {
  opacity: 0.7;
}

.reaction-btn-active {
  background-color: #E8F5E9;
}

.reaction-emoji {
  font-size: 30rpx;
}

.reaction-count {
  font-size: 24rpx;
  color: #757575;
}

/* ── 列表底部留白 ── */
.list-bottom-spacer {
  height: 160rpx;
}

/* ── FAB 悬浮发布按钮 ── */
.fab {
  position: fixed;
  right: 48rpx;
  bottom: 160rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  background-color: #4CAF50;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.40);
  z-index: 100;
}

.fab:active {
  opacity: 0.85;
  transform: scale(0.95);
}

.fab-icon {
  font-size: 44rpx;
}

/* ── 发布弹窗遮罩 ── */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.40);
  z-index: 200;
}

/* ── 发布弹窗主体 ── */
.modal-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 40rpx 60rpx;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.28s ease;
}

.modal-sheet-show {
  transform: translateY(0);
}

/* ── 弹窗头部 ── */
.modal-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 36rpx;
}

.modal-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #212121;
}

.modal-publish-btn {
  background-color: #4CAF50;
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
}

.modal-publish-btn:active {
  opacity: 0.8;
}

.modal-publish-btn-disabled {
  background-color: #BDBDBD;
}

.modal-publish-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ── 情绪选择 ── */
.modal-section-label {
  font-size: 26rpx;
  color: #9E9E9E;
  margin-bottom: 20rpx;
}

.modal-mood-row {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.modal-mood-item {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mood-item:active {
  opacity: 0.7;
}

.modal-mood-active {
  background-color: #E8F5E9;
  border: 2rpx solid #4CAF50;
}

.modal-mood-emoji {
  font-size: 40rpx;
}

/* ── 文字输入 ── */
.modal-textarea {
  width: 100%;
  min-height: 120rpx;
  background-color: #F7F3EF;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #212121;
  line-height: 1.6;
  box-sizing: border-box;
}

.modal-textarea-placeholder {
  color: #BDBDBD;
  font-size: 30rpx;
}

.modal-char-count {
  text-align: right;
  font-size: 22rpx;
  color: #BDBDBD;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

/* ── 匿名提示 ── */
.modal-anon-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.modal-anon-icon {
  font-size: 28rpx;
}

.modal-anon-text {
  font-size: 26rpx;
  color: #9E9E9E;
}